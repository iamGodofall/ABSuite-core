# ABSuite Production Environment Template
# ================================================
# Copy this to .env and generate REAL 64-char random values for production
# Use: openssl rand -hex 32 (Linux/Mac) or pwsh: [Convert]::ToHexString([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(32))
# ================================================

# Core Security (REQUIRED for GA)
CAPKIT_HMAC_SECRET=your_capkit_hmac_secret_here_64_chars_min_$(openssl_rand_hex_32)
CAPKIT_JWT_SECRET=your_capkit_jwt_secret_here_64_chars_min_$(openssl_rand_hex_32)
ABSUITE_ADMIN_API_KEY=your_admin_api_key_here_64_chars_min_$(openssl_rand_hex_32)
ABSUITE_DB_ENCRYPTION_KEY=your_db_encryption_key_64_chars_min_$(openssl_rand_hex_32)

# Origins (Update for your domain)
ABSUITE_ALLOWED_ORIGINS=http://localhost:3001,https://yourdomain.com

# Logging
ABSUITE_LOG_LEVEL=info

# Optional AI Providers
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# QUICKBENCH_OLLAMA_URL=http://host.docker.internal:11434

# ================================================
# SECURITY NOTES:
# 1. Never commit .env with real values
# 2. Rotate secrets every 90 days
# 3. Use Docker secrets or Vault in prod
# 4. Minimum 256-bit (64 hex chars) entropy
# ================================================

