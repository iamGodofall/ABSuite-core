# ABSuite Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ============================================
# Core
# ============================================
ABSUITE_ENV=development
ABSUITE_DB_PATH=./data/absuite.db
ABSUITE_LOG_LEVEL=info

# ============================================
# CapKit (Security Module)
# ============================================
CAPKIT_PORT=8081
# Generate with: openssl rand -hex 32
CAPKIT_HMAC_SECRET=change-me-with-openssl-rand-hex-32
# Generate with: openssl rand -hex 32
CAPKIT_JWT_SECRET=change-me-with-openssl-rand-hex-32

# ============================================
# Edge-Run (Execution Module)
# ============================================
EDGERUN_PORT=8082
EDGERUN_MAX_CONCURRENT=10
EDGERUN_QUEUE_LIMIT=100

# ============================================
# QuickBench (Benchmarking Module)
# ============================================
QUICKBENCH_PORT=8083
QUICKBENCH_OLLAMA_URL=http://localhost:11434

# ============================================
# Dashboard
# ============================================
DASHBOARD_PORT=3001
VITE_API_CAPKIT_URL=http://localhost:8081
VITE_API_EDGERUN_URL=http://localhost:8082
VITE_API_QUICKBENCH_URL=http://localhost:8083
